# Anthropic API — required for Jungian analysis and theme fallback
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Genius API — required for lyrics fetch (primary)
GENIUS_API_TOKEN=your_genius_client_access_token_here

# Musixmatch API — required for lyrics fetch (fallback)
MUSIXMATCH_API_KEY=your_musixmatch_api_key_here

GCS_KEY_PATH=credentials/gcs_service_account.json   # path to service account key JSON
GCS_BUCKET=billboard-mood-pipeline                   # GCS bucket name for artifact archiving
